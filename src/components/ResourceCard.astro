---
// src/components/ResourceCard.astro
const { type, title, description, link } = Astro.props;
---
<div class="p-5 bg-slate-800 border border-slate-700 rounded-xl hover:border-cyan-500/50 transition-all group">
  <div class="flex items-start justify-between mb-4">
    <div class="p-3 bg-slate-900 rounded-lg text-2xl group-hover:scale-110 transition-transform">
      {type === 'code' ? '💻' : '📄'}
    </div>
    <a href={link} class="text-xs font-bold text-cyan-400 uppercase tracking-widest hover:text-cyan-300">
      Download →
    </a>
  </div>
  <h3 class="text-white font-bold mb-2">{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed">{description}</p>
</div>