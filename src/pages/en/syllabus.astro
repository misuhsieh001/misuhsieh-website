---
import Layout from '../layouts/Layout.astro';

// 定義課程進度資料，方便維護
const schedule = [
  { week: 1, topic: "Course Overview & Introduction to SCCA", category: "Intro" },
  { week: 2, topic: "Sensation (1): Wireless Sensing & WiFi CSI", category: "Sensation" },
  { week: 3, topic: "Sensation (2): Visual Perception & Camera Calibration", category: "Sensation" },
  { week: 4, topic: "Sensation (3): Acoustic Sensing & Privacy-preserving Tech", category: "Sensation" },
  { week: 5, topic: "Lab 01: Arduino Sensor Integration (Hands-on)", category: "Lab" },
  { week: 6, topic: "Communication (1): Advanced IoT Networking & 5G/6G", category: "Communication" },
  { week: 7, topic: "Communication (2): Low-power Wide-area Network (LPWAN)", category: "Communication" },
  { week: 8, topic: "Midterm Project Proposal & Discussion", category: "Event" },
  { week: 9, topic: "Computing (1): Context-aware Computing Foundations", category: "Computing" },
  { week: 10, topic: "Computing (2): Edge AI & Distributed Intelligence", category: "Computing" },
  { week: 11, topic: "Computing (3): Serverless Computing for Pervasive Systems", category: "Computing" },
  { week: 12, topic: "Lab 02: Raspberry Pi & Edge Inference (Hands-on)", category: "Lab" },
  { week: 13, topic: "Autonomy (1): Robotics Platforms & ROS 2 Basics", category: "Autonomy" },
  { week: 14, topic: "Autonomy (2): Autonomous Coordination & Swarm Intelligence", category: "Autonomy" },
  { week: 15, topic: "Autonomy (3): Drone Applications & Navigation", category: "Autonomy" },
  { week: 16, topic: "Final Project Development & Mentoring", category: "Event" },
  { week: 17, topic: "Final Demo (Part I): System Presentation", category: "Event" },
  { week: 18, topic: "Final Demo (Part II): Future Vision & Peer Review", category: "Event" },
];

// 根據類別回傳對應的顏色標籤
const getCategoryStyle = (category) => {
  switch (category) {
    case "Sensation": return "bg-cyan-900/50 text-cyan-400 border-cyan-500/50";
    case "Communication": return "bg-blue-900/50 text-blue-400 border-blue-500/50";
    case "Computing": return "bg-indigo-900/50 text-indigo-400 border-indigo-500/50";
    case "Autonomy": return "bg-purple-900/50 text-purple-400 border-purple-500/50";
    case "Lab": return "bg-emerald-900/50 text-emerald-400 border-emerald-500/50";
    case "Event": return "bg-rose-900/50 text-rose-400 border-rose-500/50";
    default: return "bg-slate-800 text-slate-400 border-slate-700";
  }
};
---

<Layout title="課程大綱 - 行動與普適智慧">
  <main class="min-h-screen bg-slate-900 py-16 px-6">
    <div class="max-w-4xl mx-auto">
      
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-extrabold text-white mb-4">114-1 課程進度表</h1>
        <p class="text-slate-400">本課程分為兩大部分：(A) 行動平台感知與通訊、(B) 智慧生成與自主系統</p>
      </div>

      <div class="bg-slate-800/50 border border-slate-700 rounded-2xl overflow-hidden backdrop-blur-sm">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-800 border-b border-slate-700">
              <th class="py-4 px-6 text-slate-300 font-bold w-20">週次</th>
              <th class="py-4 px-6 text-slate-300 font-bold">授課主題 / 實驗內容</th>
              <th class="py-4 px-6 text-slate-300 font-bold w-32">模組分類</th>
            </tr>
          </thead>
          <tbody>
            {schedule.map((item) => (
              <tr class="border-b border-slate-700/50 hover:bg-slate-700/30 transition-colors">
                <td class="py-4 px-6 text-slate-400 font-mono">W{item.week.toString().padStart(2, '0')}</td>
                <td class="py-4 px-6 text-white font-medium">{item.topic}</td>
                <td class="py-4 px-6 text-center">
                  <span class={`text-[10px] uppercase tracking-tighter px-2 py-1 rounded border ${getCategoryStyle(item.category)}`}>
                    {item.category}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-12 p-6 bg-slate-800/30 border-l-4 border-cyan-500 rounded-r-xl">
        <h3 class="text-white font-bold mb-2">💡 助教小提醒</h3>
        <ul class="text-slate-400 text-sm space-y-2 list-disc list-inside">
          <li>課程內容會根據學生的實作進度進行微調。</li>
          <li>實驗課 (Lab) 請務必攜帶自己的筆記型電腦並預先安裝好開發環境。</li>
          <li>期末專案 (Final Project) 鼓勵跨模組整合 (例如：使用 Sensing 結合 Autonomy)。</li>
        </ul>
      </div>

    </div>
  </main>
</Layout>