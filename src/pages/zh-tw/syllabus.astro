---
// src/pages/en/syllabus.astro
import Layout from '../../layouts/Layout.astro';
import { getTermLabel } from '../../utils/term';
const termLabel = getTermLabel();

const schedule = [
  { week: 1, topic: "課程概述與 SCCA 介紹", category: "介紹" },
  { week: 2, topic: "感測 (1): 無線感測與 WiFi CSI", category: "感知" },
  { week: 3, topic: "感測 (2): 視覺感知與相機校正", category: "感知" },
  { week: 4, topic: "感測 (3): 聲學感測與隱私保護技術", category: "感知" },
  { week: 5, topic: "實驗 01: Arduino 感測器整合 (實作)", category: "實作" },
  { week: 6, topic: "通訊 (1): 先進 IoT 網路與 5G/6G", category: "通訊" },
  { week: 7, topic: "通訊 (2): 低功耗廣域網路 (LPWAN)", category: "通訊" },
  { week: 8, topic: "期中專案提案與討論", category: "專案" },
  { week: 9, topic: "計算 (1): 上下文感知計算基礎", category: "計算" },
  { week: 10, topic: "計算 (2): 邊緣 AI 與分散式智慧", category: "計算" },
  { week: 11, topic: "計算 (3): 無伺服器計算於泛在系統", category: "計算" },
  { week: 12, topic: "實驗 02: Raspberry Pi 與邊緣推論 (實作)", category: "實作" },
  { week: 13, topic: "自主 (1): 機器人平台與 ROS 2 基礎", category: "自主" },
  { week: 14, topic: "自主 (2): 自主協調與群體智慧", category: "自主" },
  { week: 15, topic: "自主 (3): 無人機應用與導航", category: "自主" },
  { week: 16, topic: "期末專案開發與指導", category: "專案" },
  { week: 17, topic: "期末展示 (第一部分): 系統展示", category: "專案" },
  { week: 18, topic: "期末展示 (第二部分): 未來展望與同儕評審", category: "專案" },
];

const getCategoryStyle = (category) => {
  switch (category) {
    case "介紹": return "bg-cyan-900/50 text-cyan-400 border-cyan-500/50";
    case "感知": return "bg-blue-900/50 text-blue-400 border-blue-500/50";
    case "通訊": return "bg-indigo-900/50 text-indigo-400 border-indigo-500/50";
    case "計算": return "bg-purple-900/50 text-purple-400 border-purple-500/50";
    case "自主": return "bg-emerald-900/50 text-emerald-400 border-emerald-500/50";
    case "專案": return "bg-rose-900/50 text-rose-400 border-rose-500/50";
    default: return "bg-slate-800 text-slate-400 border-slate-700";
  }
};
---

<Layout title="Syllabus - Mobile and Pervasive Intelligence">
  <main class="min-h-screen bg-slate-900 py-16 px-6">
    <div class="max-w-4xl mx-auto">
      
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-extrabold text-white mb-4">{termLabel} 課程大綱</h1>
        <p class="text-slate-400">本課程分為兩個主要部分：(A) 感知與通訊，(B) 智能與自主。</p>
      </div>

      <div class="bg-slate-800/50 border border-slate-700 rounded-2xl overflow-hidden backdrop-blur-sm">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-800 border-b border-slate-700">
              <th class="py-4 px-6 text-slate-300 font-bold w-20">Week</th>
              <th class="py-4 px-6 text-slate-300 font-bold">Topics / Lab Content</th>
              <th class="py-4 px-6 text-slate-300 font-bold w-32">Module</th>
            </tr>
          </thead>
          <tbody>
            {schedule.map((item) => (
              <tr class="border-b border-slate-700/50 hover:bg-slate-700/30 transition-colors">
                <td class="py-4 px-6 text-slate-400 font-mono">W{item.week.toString().padStart(2, '0')}</td>
                <td class="py-4 px-6 text-white font-medium">{item.topic}</td>
                <td class="py-4 px-6 text-center">
                  <span class={`text-[14px] uppercase tracking-tighter px-2 py-1 rounded border ${getCategoryStyle(item.category)}`}>
                    {item.category}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-12 p-6 bg-slate-800/30 border-l-4 border-cyan-500 rounded-r-xl">
        <h3 class="text-white font-bold mb-2">💡 TA 筆記</h3>
        <ul class="text-slate-400 text-sm space-y-2 list-disc list-inside">
          <li>課堂內容將根據學生進度進行小幅調整。</li>
          <li>實驗課請攜帶自己的筆電，並預先安裝所需的環境。</li>
          <li>期末專案鼓勵整合多個 SCCA 模組。</li>
        </ul>
      </div>

    </div>
  </main>
</Layout>