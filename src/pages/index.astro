---
// src/pages/en/index.astro
import Layout from '../layouts/Layout.astro'; // 注意這裡回到上一層的路徑變了
import { getTermLabel } from '../utils/term';
const termLabel = getTermLabel();
---

<Layout title="Mobile and Pervasive Intelligence | NTU CSIE 5411">
  <main class="min-h-screen bg-slate-900">
    <section class="py-24 flex flex-col items-center text-center px-4 relative overflow-hidden">
      <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-cyan-900/30 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="inline-block px-4 py-1.5 rounded-full bg-slate-800 border border-slate-700 text-cyan-400 text-sm font-semibold mb-6 tracking-wider">
        NTU CSIE 5411 • {termLabel}
      </div>
      
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight">
        Mobile & <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Pervasive Intelligence</span>
      </h1>

      <p class="text-md md:text-lg text-slate-400 max-w-3xl mb-10 leading-relaxed">
        Explore the theoretical foundations and practical applications of mobile platforms and pervasive computing. Learn to extract unknown information from ubiquitous sensors and build intelligent IoT and robotic applications.
      </p>

      <div class="flex gap-4 z-10">
        <a href="/en/labs" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white border border-slate-700 rounded-lg font-semibold transition-colors">
          View Lab Tutorials
        </a>
      </div>
    </section>
  </main>
</Layout>